# ══════════════════════════════════════
# APEX — Environment Configuration
# ══════════════════════════════════════

# ── Server ──────────────────────────
PORT=5000

# ── PostgreSQL Database (Neon/Vercel) ─
# On Vercel, this is injected automatically. Locally, paste your Neon URL here:
DATABASE_URL=postgres://neondb_owner:YOUR_PASSWORD@ep-calm-dawn-xyz.us-east-1.aws.neon.tech/neondb?sslmode=require

# Local fallback:
DB_USER=postgres
DB_HOST=localhost
DB_NAME=clozr_db
DB_PASSWORD=your_password_here
DB_PORT=5432

# ── OpenAI API ──────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ── WhatsApp Business API (Meta) ────
WHATSAPP_PHONE_ID=your_phone_number_id
WHATSAPP_TOKEN=your_access_token
OWNER_WHATSAPP_NUMBER=your_personal_whatsapp_number

# ── Gmail / Email ───────────────────
GMAIL_FROM=your-email@gmail.com
GMAIL_APP_PASSWORD=your_app_password

# ── n8n Webhook URLs ────────────────
N8N_BASE_URL=http://localhost:5678
N8N_SCRAPER_WEBHOOK=/webhook/scrape-google-maps
N8N_LINKEDIN_WEBHOOK=/webhook/scrape-linkedin
N8N_GENERATE_WEBHOOK=/webhook/generate-messages
N8N_REPLY_WEBHOOK=/webhook/reply-webhook
